{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "世界": {
      "type": "object",
      "properties": {
        "当前时间": {
          "type": "string"
        },
        "当前地点": {
          "type": "string"
        },
        "公开常识版本": {
          "type": "string"
        },
        "当前规则摘要": {
          "type": "string"
        },
        "规则稳定度": {
          "type": "number"
        },
        "最近变更": {
          "type": "object",
          "propertyNames": {
            "type": "string",
            "description": "变更代号"
          },
          "additionalProperties": {
            "type": "object",
            "properties": {
              "说明": {
                "type": "string"
              },
              "影响范围": {
                "type": "string"
              },
              "杨世发观测": {
                "type": "string"
              }
            },
            "required": [
              "说明",
              "影响范围",
              "杨世发观测"
            ]
          }
        }
      },
      "required": [
        "当前时间",
        "当前地点",
        "公开常识版本",
        "当前规则摘要",
        "规则稳定度",
        "最近变更"
      ]
    },
    "杨世发": {
      "type": "object",
      "properties": {
        "年龄": {
          "type": "number"
        },
        "身份": {
          "type": "string"
        },
        "年级": {
          "type": "string"
        },
        "当前位置": {
          "type": "string"
        },
        "当前目标": {
          "type": "string"
        },
        "认知状态": {
          "type": "string"
        },
        "异常认知压力": {
          "type": "number"
        },
        "对世界异常的怀疑": {
          "type": "number"
        },
        "社会伪装程度": {
          "type": "number"
        },
        "随身物品": {
          "type": "object",
          "propertyNames": {
            "type": "string",
            "description": "物品名"
          },
          "additionalProperties": {
            "type": "object",
            "properties": {
              "描述": {
                "type": "string"
              },
              "数量": {
                "type": "number"
              }
            },
            "required": [
              "描述",
              "数量"
            ]
          }
        }
      },
      "required": [
        "年龄",
        "身份",
        "年级",
        "当前位置",
        "当前目标",
        "认知状态",
        "异常认知压力",
        "对世界异常的怀疑",
        "社会伪装程度",
        "随身物品"
      ]
    },
    "调试者遮蔽": {
      "type": "object",
      "properties": {
        "_存在事实": {
          "type": "string"
        },
        "_身份状态": {
          "type": "string"
        },
        "_交流许可": {
          "type": "boolean"
        },
        "_互知许可": {
          "type": "boolean"
        },
        "遮蔽强度": {
          "type": "number"
        },
        "叙事备注": {
          "type": "string"
        }
      },
      "required": [
        "_存在事实",
        "_身份状态",
        "_交流许可",
        "_互知许可",
        "遮蔽强度",
        "叙事备注"
      ]
    }
  },
  "required": [
    "世界",
    "杨世发",
    "调试者遮蔽"
  ]
}