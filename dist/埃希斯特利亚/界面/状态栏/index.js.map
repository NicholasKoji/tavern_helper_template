export default {'主角':{'姓名':'杨世发','年龄':18,'san值':100},'当前场景':{'时间':{'年':2186,'月':6,'日':14,'时':14,'分':35},'地点':{'一级区域':'埃斯图拉','二级区域':'社会管理局','三级区域':'拘留室'},'天气':{'概况':'阴天','气温':{'数值':24,'单位':'°C'},'风':'海风偏湿','体感':'室外潮湿，室内空气略闷。'},'环境':'金属询问桌横在房间中央，封闭灯光照得桌面发白，空气里残留微甜的消毒剂气味。'},'待办事项':{'主要':'等待社会管理局对杨世发的无档案情况作出初步安置决定。','次要':'在赵锋离开期间，与苏晴进行第一次直接交流。'},'骑士':{'赵锋':{'年龄':23,'身份':'社会管理局巡逻骑士','外貌':'赵锋身形挺拔，肩背端正，黑发修剪得短而整齐；五官轮廓清晰，眼神稳定，穿着社会管理局制服时显得克制、干净，有一种不轻易被情绪牵动的职业感。','性格':'赵锋习惯先看证据和流程，再决定下一步怎么处理；他说话不急不缓，很少用压迫感逼人就范，但也不会因为对方慌乱就轻易放松判断。','态度':'将杨世发视为需要上报的异常个案，暂时没有敌意，但保持明确的职业警惕。','好感度':0,'当前心理':'我处理过登记异常和临时失忆的个案，但这个少年的信息空白太完整了。继续在这里追问意义不大，先上报协调节点，等正式口径下来再处理。','当前动作':'离开拘留室，将杨世发的异常档案上报至社会管理局协调节点。'}},'女骑':{'苏晴':{'年龄':23,'身份':'专属女骑','所属骑士':'赵锋','所属关系':'学院官方配对形成的专属关系','关系背景':'苏晴与赵锋不是直系亲属，而是同龄进入骑术学院，在配对训练中形成稳定组合，毕业后登记为法定专属关系。成为赵锋的专属女骑后，她与赵锋共同生活，负责他的日常出行、骑乘滑行和公务随行，两人已经熟悉彼此的节奏与身体控制习惯。','外貌':{'体型':'身形修长匀称，腰线柔韧，肩背与腿部带着长期滑行训练留下的紧致感；站立时姿态端正，进入低姿滑行时四肢线条会显得格外流畅。','头发':'一头柔顺的深棕色长发，平日束成低马尾，发丝贴过耳侧时露出白皙的颈线；运动后，几缕碎发常被汗意黏在脸颊边。','眉眼':'双眉如远山含黛，眉尾柔柔垂下，微微蹙起时带着一点惹人怜惜的脆弱感；一双清澈杏眼水光很亮，安静注视别人时像在认真分辨对方每一句话。','鼻梁':'鼻梁秀挺而不锋利，鼻尖小巧，侧脸在灯光下有一种柔和的起伏。','唇口':'唇形柔软，唇珠浅浅，平时唇色偏淡；紧张时会轻轻抿住下唇，像是把没说出口的话含在齿间。','脸部轮廓':'脸部轮廓偏鹅蛋形，脸颊柔和，下颌线收得细而干净；低头时显得温顺，抬眼看人时又会露出一点不易察觉的倔意。','皮肤':'肤色白净细腻，耳后、颈侧和脸颊在运动后容易浮起浅粉色；被人盯着看得太久时，那层红意会从耳尖慢慢蔓到脸侧。'},'身材':{'胸部':{'身材描述':'身形修长却拥有饱满的D罩杯，乳形丰润挺翘，上胸弧度柔和、下缘沉坠感分明；站立时侧面形成清晰的重量线，低姿滑行时双乳随躯干前倾而自然垂坠，乳沟在挤压中收得更深。','罩杯':'D','当前状态':'高强度滑行后胸前汗意明显，乳沟与下缘皮肤因汗液与高弹内衬贴合而泛着湿润的光泽；乳头在持续摩擦下充血挺立，颜色比平时略深，乳晕边缘因体温升高漫开一圈浅玫瑰色；每次喘息时胸部随肋骨的起伏轻微晃动，汗水沿乳沟缓缓滑落。'},'臀部':{'身材描述':'饱满的蜜桃臀，臀峰高翘、臀线圆隆，侧面弧线从腰窝下方向上拱起再收向腿根，形成明显的桃形轮廓；臀肉紧弹而不松垮，低姿滑行时臀瓣自然分开显露深沟，饱满的臀侧会将贴身的连体衣布料撑出柔和的张力线。','当前状态':'骑乘滑行后臀尖与大腿内侧残留大片潮红，坐姿下臀瓣被椅面压扁、臀肉向两侧微微挤开；臀沟深处因长时间挤压蓄着薄汗与体液混合的湿润感，开裆边缘的皮肤在摩擦后泛着浅红色印痕，未干体液在腿根内侧留下数道半透明的反光。'},'足部':{'身材描述':'足型偏窄长，足弓弧度适中，趾节分明而不突兀；脚背皮肤薄而白皙，隐约可见浅青色血管；长期滑行训练使前掌略微有力，足踝线条利落。','当前状态':'滑行后足部微热，前掌与趾腹因持续支撑略有压迫红痕；轮滑服足部护具刚卸下不久，皮肤上残留内衬的浅淡织物压印。'}},'性格':'苏晴待人温和，观察细致，不喜欢把场面弄得难堪；她习惯照顾赵锋的节奏，也习惯在规程允许的范围内保留自己的判断。','态度':'对杨世发保持观察，因他的反应明显不同于本地骑士而产生好奇。','好感度':0,'当前心理':'他刚才的反应不像普通紧张，更像是真的不明白这里的一切为什么理所当然。赵锋不在，我得小心一点，但也许可以先听听他会怎么说。','当前动作':'坐在独立靠背椅上待命，双腿交叠，尚未卸下女骑轮滑服。','体力':72,'装备':{'女骑轮滑服':{'描述':'深色高弹力连体式女骑轮滑服紧贴她的躯干与四肢，腰臀处嵌有承重接口，前臂与小腿护具下方安装竖列轮组，整体线条干净而贴身。','状态':'已穿戴，经过刚才的骑乘滑行后略有压痕和使用痕迹。'},'前臂轮组':{'描述':'轮组收在前臂护具下方，竖列滑轮在灯光下反出细窄亮线。','状态':'正常'},'小腿轮组':{'描述':'小腿护具下方的轮组更长，适合在低姿滑行中承担后段支撑。','状态':'正常'},'骑乘座椅':{'描述':'与腰臀承重接口配套的低背骑乘座椅，卡扣、束带和支架都已经解开。','状态':'已卸下，放在拘留室地面。'}},'机动能力':{'最高时速':{'数值':35,'单位':'km/h'},'巡航距离':{'数值':18,'单位':'km'},'承载稳定':{'数值':1.8,'单位':'m/s²'},'操控响应':{'数值':0.48,'单位':'s'},'动力转化效率':{'数值':61,'单位':'百分比'}}}}};